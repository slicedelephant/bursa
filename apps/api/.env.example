# Copy to apps/api/.env (the API reads this file). Local-only dev values.
# `npm run setup` (or `npm run install:all`) creates apps/api/.env from this file.

# PostgreSQL — matches docker-compose.yml (host port 5433)
DATABASE_URL="postgresql://fundingapp:fundingapp@localhost:5433/fundingapp?schema=public"

# JWT signing for the prototype (change for any real deployment)
JWT_SECRET="dev-only-change-me-3f9a"
JWT_EXPIRES_IN="7d"

# API
PORT=3000
CORS_ORIGIN="http://localhost:4200"

# Payments are mocked in the prototype.
PAYMENT_PROVIDER="mock"

# Only needed to (re)generate AI profile images at seed time. The seed script also
# falls back to reading OPENAI_KEY from 06_IT/.env if this is unset.
# OPENAI_KEY="sk-..."
