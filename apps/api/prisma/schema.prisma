// Bursa — Funding Platform. Schema derived from specs/001-bursa-funding-platform/data-model.md.
// Money is stored as integer cents (EUR). IDs are cuid().

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  DONOR
  SPONSOR
  ADMIN
}

enum CampaignStatus {
  DRAFT
  PENDING_VERIFICATION
  LIVE
  FUNDED
  DISBURSED
  CLOSED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DonationMethod {
  CARD
  SEPA
}

enum DonationType {
  PRIVATE
  CORPORATE
}

enum DonationStatus {
  PENDING
  PLEDGED
  CAPTURED
  SUCCEEDED
  FAILED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  SENT
  CONFIRMED
}

enum UpdateType {
  MANUAL
  SYSTEM
}

enum TributeType {
  HONOR
  MEMORY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum NotificationType {
  THANK_YOU
  MILESTONE
  IMPACT_UPDATE
  GOAL_REACHED
  RECURRING_CHARGE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum SponsorshipTier {
  SEMESTER
  YEAR
  FULL
  CUSTOM
}

enum RecognitionKind {
  ANONYMOUS
  LOGO
  NAMED
}

enum InvoiceDocType {
  DONATION
  SPONSORING
}

enum InvoiceStatus {
  ISSUED
  PENDING
  PAID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(DONOR)
  displayName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile   StudentProfile?
  corporateProfile CorporateProfile?
  donations        Donation[]            @relation("DonorDonations")
  updates          CampaignUpdate[]
  verifications    AdmissionVerification[] @relation("VerifiedBy")
  recurringPledges RecurringPledge[]     @relation("DonorRecurring")
  subscriptions    UpdateSubscription[]  @relation("DonorSubscriptions")
  notifications    Notification[]
}

model School {
  id               String   @id @default(cuid())
  name             String
  country          String
  city             String?
  website          String?
  logoUrl          String?
  payoutVerified   Boolean  @default(false)
  payoutAccountRef String?
  createdAt        DateTime @default(now())

  campaigns Campaign[]
  payouts   Payout[]
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  country        String
  photoUrl       String?
  story          String
  recommendation String?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?
}

model Campaign {
  id               String         @id @default(cuid())
  studentProfileId String         @unique
  schoolId         String
  programName      String
  title            String
  story            String
  storyBackground  String?
  storyChallenge   String?
  storyVision      String?
  videoUrl         String?
  goalCents        Int
  currency         String         @default("EUR")
  raisedCents      Int            @default(0)
  tipsCents        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  deadline         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  studentProfile StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  school         School                 @relation(fields: [schoolId], references: [id])
  verification   AdmissionVerification?
  donations      Donation[]
  updates        CampaignUpdate[]
  payout         Payout?
  recurringPledges RecurringPledge[]
  subscriptions    UpdateSubscription[]
  notifications    Notification[]
  sponsorships     CorporateSponsorship[]

  @@index([status])
  @@index([schoolId])
}

model AdmissionVerification {
  id           String             @id @default(cuid())
  campaignId   String             @unique
  status       VerificationStatus @default(PENDING)
  admissionRef String?
  note         String?
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime           @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation("VerifiedBy", fields: [verifiedById], references: [id])
}

model Donation {
  id                 String         @id @default(cuid())
  campaignId         String
  donorUserId        String?
  corporateProfileId String?
  amountCents        Int
  tipCents           Int            @default(0)
  currency           String         @default("EUR")
  method             DonationMethod
  type               DonationType
  status             DonationStatus @default(PENDING)
  providerRef        String?
  pledgeRef          String?
  capturedAt         DateTime?
  message            String?
  anonymous          Boolean        @default(false)
  donorName          String?
  recurringPledgeId  String?
  tributeType        TributeType?
  tributeName        String?
  createdAt          DateTime       @default(now())

  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorUser        User?             @relation("DonorDonations", fields: [donorUserId], references: [id])
  corporateProfile CorporateProfile? @relation(fields: [corporateProfileId], references: [id])
  recurringPledge  RecurringPledge?  @relation(fields: [recurringPledgeId], references: [id])
  sponsorship      CorporateSponsorship?

  @@index([campaignId])
  @@index([donorUserId])
  @@index([recurringPledgeId])
}

model RecurringPledge {
  id                String          @id @default(cuid())
  donorUserId       String
  campaignId        String
  amountCents       Int
  currency          String          @default("EUR")
  status            RecurringStatus @default(ACTIVE)
  chargesCount      Int             @default(0)
  totalChargedCents Int             @default(0)
  nextRunAt         DateTime
  lastChargedAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  donorUser User       @relation("DonorRecurring", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([donorUserId])
  @@index([campaignId])
  @@index([status, nextRunAt])
}

model UpdateSubscription {
  id          String   @id @default(cuid())
  donorUserId String
  campaignId  String
  createdAt   DateTime @default(now())

  donorUser User     @relation("DonorSubscriptions", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([donorUserId, campaignId])
  @@index([campaignId])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String
  campaignId  String?
  emailLogged Boolean             @default(false)
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model CorporateProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  sector      String?
  contactName String?
  logoUrl     String?
  createdAt   DateTime @default(now())

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  donations    Donation[]
  sponsorships CorporateSponsorship[]
}

model Payout {
  id          String       @id @default(cuid())
  campaignId  String       @unique
  schoolId    String
  amountCents Int
  method      DonationMethod @default(SEPA)
  reference   String
  status      PayoutStatus @default(PENDING)
  proofNote   String?
  createdAt   DateTime     @default(now())
  sentAt      DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [schoolId], references: [id])
}

model CampaignUpdate {
  id         String     @id @default(cuid())
  campaignId String
  authorId   String?
  title      String
  body       String
  type       UpdateType @default(MANUAL)
  createdAt  DateTime   @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id])

  @@index([campaignId])
}

model CorporateSponsorship {
  id                 String          @id @default(cuid())
  donationId         String          @unique
  corporateProfileId String
  campaignId         String
  tier               SponsorshipTier
  fullTuition        Boolean         @default(false)
  scholarshipName    String?
  logoRecognition    Boolean         @default(false)
  recognitionKind    RecognitionKind @default(ANONYMOUS)
  impactReportOptIn  Boolean         @default(false)
  poNumber           String?
  vatId              String?
  createdAt          DateTime        @default(now())

  donation         Donation         @relation(fields: [donationId], references: [id], onDelete: Cascade)
  corporateProfile CorporateProfile @relation(fields: [corporateProfileId], references: [id], onDelete: Cascade)
  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invoice          Invoice?

  @@index([corporateProfileId])
  @@index([campaignId])
}

model Invoice {
  id            String         @id @default(cuid())
  sponsorshipId String         @unique
  invoiceNo     String         @unique
  documentType  InvoiceDocType
  netCents      Int
  vatCents      Int
  grossCents    Int
  currency      String         @default("EUR")
  vatId         String?
  poNumber      String?
  status        InvoiceStatus  @default(ISSUED)
  settledAt     DateTime?
  issuedAt      DateTime       @default(now())

  sponsorship CorporateSponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
}
