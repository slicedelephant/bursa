// Bursa — Funding Platform. Schema derived from specs/001-bursa-funding-platform/data-model.md.
// Money is stored as integer cents (EUR). IDs are cuid().

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  DONOR
  SPONSOR
  ADMIN
  SCHOOL_ADMIN
}

/// Self-serve onboarding state machine for a partner school (E8). The transitions
/// are owned by the pure `onboarding-status.ts` util; a school can only approve
/// campaigns and receive payouts once it reaches ACTIVE.
enum SchoolOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  ACTIVE
}

enum CampaignStatus {
  DRAFT
  PENDING_VERIFICATION
  LIVE
  FUNDED
  DISBURSED
  CLOSED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DonationMethod {
  CARD
  SEPA
}

enum DonationType {
  PRIVATE
  CORPORATE
}

enum DonationStatus {
  PENDING
  PLEDGED
  CAPTURED
  SUCCEEDED
  FAILED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  SENT
  CONFIRMED
}

enum UpdateType {
  MANUAL
  SYSTEM
}

enum TributeType {
  HONOR
  MEMORY
}

// ---- E15: referral & advocate engine ----
enum ReferralKind {
  REFERRAL // donor invites a friend (E4 donor account)
  ADVOCATE // student invites advocates to promote a campaign
}

enum AdvocateInviteStatus {
  ACTIVE
  REVOKED
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum NotificationType {
  THANK_YOU
  MILESTONE
  IMPACT_UPDATE
  GOAL_REACHED
  RECURRING_CHARGE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

// ---- E17: multi-channel impact feed ----
/// E17 Impact-Feed: lifecycle of a student thank-you message. Only APPROVED
/// messages enter the feed / are fanned out; the decision is owned by the pure
/// `voice-moderation.ts` (reusing the E9 keyword filter).
enum StudentMessageStatus {
  PENDING
  APPROVED
  REJECTED
}

/// E17 Impact-Feed: the channels a donor can opt into. IN_APP is always on
/// (the primary feed); EMAIL/PUSH/WHATSAPP/TELEGRAM/MESSENGER are opt-in only
/// and (for the messenger/push ones) delivered via the swappable, mocked
/// MessagingProvider. Distinct from the E4 `NotificationChannel`.
enum FeedChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
  TELEGRAM
  MESSENGER
}

/// E18 Groups-Engine: one engine, two modes. A COHORT is a student fundraising
/// team (sub-campaigns roll into a shared goal); a GIVING_CIRCLE is a donor
/// circle (contributions roll into a shared goal). Both share membership, roles,
/// leaderboard, invites, voting, chat and analytics.
enum GroupMode {
  COHORT
  GIVING_CIRCLE
}

enum GroupVisibility {
  PRIVATE
  PUBLIC
}

/// E18 Groups-Engine: per-group role. ADMIN manages members/invites/votes and can
/// trigger a cohort match; CONTRIBUTOR contributes/votes/chats; VIEWER reads only.
enum GroupRole {
  ADMIN
  CONTRIBUTOR
  VIEWER
}

enum GroupInviteStatus {
  ACTIVE
  REVOKED
  USED
}

enum GroupVoteStatus {
  OPEN
  CLOSED
}

enum GroupMessageStatus {
  APPROVED
  REJECTED
}

enum SponsorshipTier {
  SEMESTER
  YEAR
  FULL
  CUSTOM
}

enum RecognitionKind {
  ANONYMOUS
  LOGO
  NAMED
}

enum InvoiceDocType {
  DONATION
  SPONSORING
}

enum InvoiceStatus {
  ISSUED
  PENDING
  PAID
}

/// E9 Trust-and-Safety: lifecycle of a campaign moderation case. Transitions are
/// owned by the pure `moderation-rules.ts` (`decideModeration`); REJECT freezes
/// the campaign.
enum ModerationStatus {
  OPEN
  APPROVED
  REJECTED
  ESCALATED
}

/// E9 Trust-and-Safety: derived risk band for a numeric score (fraud-score.ts /
/// donor-risk.ts). Drives queue sorting and heat-map colouring.
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// E9 Trust-and-Safety: dispute lifecycle. Transitions in `chargeback-rules.ts`.
enum ChargebackStatus {
  OPEN
  EVIDENCE_SUBMITTED
  REFUND_OFFERED
  WON
  LOST
}

/// E9 Trust-and-Safety: reason a community member reports a campaign.
enum FlagReason {
  SCAM
  DUPLICATE
  INAPPROPRIATE
  MISLEADING
  OTHER
}

/// E9 Trust-and-Safety: lifecycle of a community flag.
enum FlagStatus {
  OPEN
  REVIEWED
  DISMISSED
}

/// E10 AI Coach: which kind of text a coach generation produced.
enum AiGenerationKind {
  TITLE
  STORY
  SHARE
}

/// E11 KYC: who is being verified by a verification case.
enum VerificationSubject {
  STUDENT
  SPONSOR
}

/// E11 KYC: status of a verification case. Transitions are owned by the pure
/// `verification-state.ts`; any exception lands in MANUAL_REVIEW, never a silent
/// pass.
enum VerificationCaseStatus {
  STARTED
  LIVENESS_PASSED
  DOCUMENT_VERIFIED
  AML_CLEARED
  VERIFIED
  MANUAL_REVIEW
  REJECTED
}

/// E11 KYC: status of a case in the manual-review queue (operator fallback).
enum ReviewQueueStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

/// E11 KYC: outcome of an AML screening (pure `aml-decision.ts`). BLOCKED is a
/// hard sanctioned-country block; HIT routes to manual review; CLEAR passes.
enum AmlDecision {
  CLEAR
  HIT
  BLOCKED
}

/// E12 Payout-Reconciliation: which money movement a ledger entry represents.
/// The append-only ledger (a reusable primitive E14 will build on) writes one
/// immutable entry per movement. Money always flows to the school.
enum LedgerEntryType {
  DONATION
  PAYOUT
  DISBURSEMENT
}

/// E12 Payout-Reconciliation: the reconciliation state of a system payout vs the
/// bank feed. Derived by the pure `reconciliation-matcher.ts` / `discrepancy-
/// detector.ts`; never mutates the money path.
enum ReconciliationStatus {
  MATCHED
  PENDING
  UNMATCHED
  DISCREPANCY
}

/// E13 Employer-Matching: lifecycle of a donor's match claim. Transitions are owned
/// by the pure `claim-status.ts`. A CLAIMED claim has already committed its match
/// funds to the campaign (a normal CORPORATE donation); money still flows only to
/// the school.
enum MatchClaimStatus {
  DETECTED
  OFFERED
  CLAIMED
  SUBMITTED
  APPROVED
  REJECTED
  EXPIRED
}

/// E13 Employer-Matching: how deeply an employer program integrates, which decides
/// the claim artefact: a pre-filled application link (AUTO_SUBMIT / PORTAL) or a
/// generated confirmation PDF (MANUAL, via the reused E5 buildSimplePdf).
enum EmployerIntegrationLevel {
  AUTO_SUBMIT
  PORTAL
  MANUAL
}

/// E14 ESG/CSRD: the ESG/CSR category a ledger entry is tagged with. Tagging is
/// additive (a separate EsgTag row), never a mutation of the append-only ledger.
enum EsgCategory {
  QUALITY_EDUCATION
  GENDER_EQUALITY
  GEOGRAPHIC_REACH
  POVERTY_REDUCTION
  ECONOMIC_GROWTH
}

/// E14 ESG/CSRD: the reporting standard a generated report is mapped onto. The
/// mapping (pure `esg-standard-mapper.ts`) is illustrative, not a certified
/// disclosure schema.
enum ReportStandard {
  GRI_2024
  CSRD_ESRS
  SASB
  UN_SDG
}

/// E14 ESG/CSRD: optional diversity dimension captured at scholar onboarding.
/// Always optional — capturing it never breaks the E8 admission / E11 KYC flows.
enum Gender {
  FEMALE
  MALE
  NON_BINARY
  UNDISCLOSED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(DONOR)
  displayName  String
  anonymizedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  studentProfile     StudentProfile?
  corporateProfile   CorporateProfile?
  donations          Donation[]              @relation("DonorDonations")
  updates            CampaignUpdate[]
  verifications      AdmissionVerification[] @relation("VerifiedBy")
  recurringPledges   RecurringPledge[]       @relation("DonorRecurring")
  subscriptions      UpdateSubscription[]    @relation("DonorSubscriptions")
  notifications      Notification[]
  auditLogs          AuditLog[]              @relation("AuditActor")
  schoolAdmin        SchoolAdmin?
  reviewedAdmissions AdmissionRecord[]       @relation("AdmissionReviewer")

  // ---- E9: trust & safety (donor account freeze + risk score) ----
  frozen       Boolean   @default(false)
  frozenAt     DateTime?
  freezeReason String?
  riskScore    Int       @default(0)
  riskLevel    RiskLevel @default(LOW)

  fraudSignals      FraudSignal[]    @relation("DonorFraud")
  moderationReviews ModerationCase[] @relation("ModerationReviewer")
  campaignFlags     CampaignFlag[]   @relation("FlagReporter")

  // ---- E10: AI fundraising coach (per-user token budget + generation log) ----
  aiTokenBudget AiTokenBudget?
  aiGenerations AiGeneration[]

  // ---- E11: KYC & verification (cases the user is subject of / reviewed) ----
  verificationCases   VerificationCase[] @relation("VerificationSubject")
  verificationReviews VerificationCase[] @relation("VerificationReviewer")

  // ---- E12: payout reconciliation (movements this user acted on) ----
  ledgerEntries LedgerEntry[] @relation("LedgerActor")

  // ---- E13: employer matching (detected employer + remaining annual balance) ----
  /// Detected employer + work-email domain (set on a logged-in DONOR after a
  /// successful match detection). Never required, never on the money path.
  employerName   String?
  employerDomain String?
  /// Calendar year the current match balance applies to (implicit yearly reset).
  matchYear      Int?
  /// Match euros (cents) already committed this `matchYear`. Reset when the year rolls.
  matchUsedCents Int     @default(0)

  matchClaims   MatchClaim[]         @relation("DonorMatchClaims")
  // ---- E14: ESG/CSRD reporting (compliance records this user created) ----
  esgTags       EsgTag[]             @relation("EsgTagTagger")
  esgReports    EsgReport[]          @relation("EsgReportCreator")
  auditorGrants AuditorAccessGrant[] @relation("AuditorGrantCreator")

  // ---- E15: referral & advocate engine (one referral link per donor) ----
  referralLink ReferralLink? @relation("DonorReferralLink")

  // ---- E17: multi-channel impact feed (donor channel opt-ins + feed reads) ----
  channelPrefs NotificationChannelPref[] @relation("DonorChannelPrefs")
  feedReads    FeedRead[]                @relation("DonorFeedReads")

  // ---- E18: groups engine (cohort teams + giving circles) ----
  groupMemberships   GroupMember[]       @relation("GroupMemberships")
  groupContributions GroupContribution[] @relation("GroupContributions")
  groupMessages      GroupMessage[]      @relation("GroupMessages")
  groupBallots       GroupVoteBallot[]   @relation("GroupBallots")
}

/// Append-only access/security audit trail. Metadata is PII-redacted before
/// it is persisted (see SecurityModule's AuditService).
model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String?
  targetType  String?
  targetId    String?
  ip          String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorUserId])
}

/// Privacy-aware product/funnel analytics (E7). visitorId is an anonymous,
/// client-generated id (never IP, no PII). metadata is PII-redacted before it is
/// persisted (see ObservabilityModule/AnalyticsService). Soft references only
/// (no FK constraints) so analytics never blocks a business operation.
model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String
  visitorId  String?
  sessionId  String?
  userId     String?
  campaignId String?
  path       String?
  step       String?
  requestId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([campaignId])
}

model School {
  id               String   @id @default(cuid())
  name             String
  country          String
  city             String?
  website          String?
  logoUrl          String?
  /// URL-safe handle for the branded school-admin portal (E8). Optional/unique.
  slug             String?  @unique
  payoutVerified   Boolean  @default(false)
  payoutAccountRef String?
  createdAt        DateTime @default(now())

  // ---- E8: self-serve onboarding + payout data ----
  onboardingStatus    SchoolOnboardingStatus @default(NOT_STARTED)
  bankAccountName     String?
  iban                String?
  bic                 String?
  taxId               String?
  contactName         String?
  contactEmail        String?
  /// Mock e-signature audit fields (no real DocuSign call — see EsignatureProvider).
  agreementSignedAt   DateTime?
  agreementSignerName String?
  agreementRef        String?

  campaigns        Campaign[]
  payouts          Payout[]
  admins           SchoolAdmin[]
  admissionRecords AdmissionRecord[]
  onboardingTokens SchoolOnboardingToken[]
  webhookEvents    SchoolWebhookEvent[]

  // ---- E12: payout reconciliation + append-only ledger ----
  ledgerEntries    LedgerEntry[]
  bankTransactions BankTransaction[]
  reconciliations  Reconciliation[]
}

/// Binds a User (role SCHOOL_ADMIN) to exactly one School (E8). One user admins
/// one school in the prototype; a school may have several admins.
model SchoolAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  schoolId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// A row from an imported admission list (E8). A VERIFIED admission is the
/// trust anchor that lets a matching student campaign go live (Constitution II).
model AdmissionRecord {
  id           String             @id @default(cuid())
  schoolId     String
  studentEmail String
  studentName  String
  programName  String
  admissionRef String
  status       VerificationStatus @default(PENDING)
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  reviewedBy        User?              @relation("AdmissionReviewer", fields: [reviewedById], references: [id])
  verificationCases VerificationCase[]

  @@unique([schoolId, admissionRef])
  @@index([schoolId, status])
}

/// Single-use, hashed onboarding link token for the hosted registration flow
/// (E8, à la Stripe Connect). Only the SHA-256 hash is stored, never the raw token.
model SchoolOnboardingToken {
  id        String    @id @default(cuid())
  schoolId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// Logged outbound school webhook event (E8). The prototype emitter only persists
/// + structured-logs the event; real HTTP delivery/retries are out of scope.
model SchoolWebhookEvent {
  id        String   @id @default(cuid())
  schoolId  String
  type      String
  status    String   @default("LOGGED")
  payload   Json
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  country        String
  photoUrl       String?
  story          String
  recommendation String?
  createdAt      DateTime @default(now())
  // ---- E14: optional diversity fields (CSRD/diversity reporting). All nullable;
  // capturing them never breaks E8 onboarding / E11 KYC. `country` already exists.
  gender         Gender?
  birthYear      Int?
  firstGen       Boolean?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?
}

model Campaign {
  id               String         @id @default(cuid())
  studentProfileId String         @unique
  schoolId         String
  programName      String
  title            String
  story            String
  storyBackground  String?
  storyChallenge   String?
  storyVision      String?
  videoUrl         String?
  goalCents        Int
  currency         String         @default("EUR")
  raisedCents      Int            @default(0)
  tipsCents        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  deadline         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // ---- E9: trust & safety (freeze flags; never touches the money path) ----
  frozen       Boolean   @default(false)
  frozenAt     DateTime?
  freezeReason String?

  studentProfile   StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  school           School                 @relation(fields: [schoolId], references: [id])
  verification     AdmissionVerification?
  donations        Donation[]
  updates          CampaignUpdate[]
  payout           Payout?
  recurringPledges RecurringPledge[]
  subscriptions    UpdateSubscription[]
  notifications    Notification[]
  sponsorships     CorporateSponsorship[]
  moderationCase   ModerationCase?
  flags            CampaignFlag[]
  chargebacks      Chargeback[]
  matchClaims      MatchClaim[]

  // ---- E15: referral & advocate engine ----
  advocateInvites AdvocateInvite[]

  // ---- E17: multi-channel impact feed (moderated student voice messages) ----
  studentMessages StudentMessage[]

  // ---- E18: groups engine (cohort sub-campaign links + vote options) ----
  groupLinks  GroupCampaign[]   @relation("GroupCampaigns")
  voteOptions GroupVoteOption[] @relation("GroupVoteCampaign")

  @@index([status])
  @@index([schoolId])
}

model AdmissionVerification {
  id           String             @id @default(cuid())
  campaignId   String             @unique
  status       VerificationStatus @default(PENDING)
  admissionRef String?
  note         String?
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime           @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation("VerifiedBy", fields: [verifiedById], references: [id])
}

model Donation {
  id                 String         @id @default(cuid())
  campaignId         String
  donorUserId        String?
  corporateProfileId String?
  amountCents        Int
  tipCents           Int            @default(0)
  currency           String         @default("EUR")
  method             DonationMethod
  type               DonationType
  status             DonationStatus @default(PENDING)
  providerRef        String?
  pledgeRef          String?
  capturedAt         DateTime?
  message            String?
  anonymous          Boolean        @default(false)
  donorName          String?
  /// Optional self-declared donor country, used only for the school dashboard's
  /// donor-geography breakdown (E8). Never required, never PII-linked.
  donorCountry       String?
  recurringPledgeId  String?
  tributeType        TributeType?
  tributeName        String?
  createdAt          DateTime       @default(now())

  campaign         Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorUser        User?                 @relation("DonorDonations", fields: [donorUserId], references: [id])
  corporateProfile CorporateProfile?     @relation(fields: [corporateProfileId], references: [id])
  recurringPledge  RecurringPledge?      @relation(fields: [recurringPledgeId], references: [id])
  sponsorship      CorporateSponsorship?
  fraudSignals     FraudSignal[]
  chargebacks      Chargeback[]

  // ---- E13: employer matching ----
  /// When this donation triggered an employer-match claim (the donor's own gift).
  triggeredClaim MatchClaim? @relation("TriggeringDonation")
  /// When this donation IS the committed employer-match (a CORPORATE donation).
  matchClaim     MatchClaim? @relation("MatchDonation")

  // ---- E15: referral attribution (money-free; a donation counts at most once) ----
  referralAttribution ReferralAttribution? @relation("DonationReferral")

  // ---- E18: groups engine (money-free circle contribution mirror) ----
  groupContribution GroupContribution? @relation("GroupContributionDonation")

  @@index([campaignId])
  @@index([donorUserId])
  @@index([recurringPledgeId])
}

model RecurringPledge {
  id                String          @id @default(cuid())
  donorUserId       String
  campaignId        String
  amountCents       Int
  currency          String          @default("EUR")
  status            RecurringStatus @default(ACTIVE)
  chargesCount      Int             @default(0)
  totalChargedCents Int             @default(0)
  nextRunAt         DateTime
  lastChargedAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  donorUser User       @relation("DonorRecurring", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([donorUserId])
  @@index([campaignId])
  @@index([status, nextRunAt])
}

model UpdateSubscription {
  id          String   @id @default(cuid())
  donorUserId String
  campaignId  String
  createdAt   DateTime @default(now())

  donorUser User     @relation("DonorSubscriptions", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([donorUserId, campaignId])
  @@index([campaignId])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String
  campaignId  String?
  emailLogged Boolean             @default(false)
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

/// E17 Impact-Feed: a moderated student thank-you message. Video/voice are URLs
/// only (no upload pipeline). Only APPROVED rows surface in the feed and are
/// fanned out to opted-in donors via the MessagingProvider. Money-free.
model StudentMessage {
  id               String               @id @default(cuid())
  campaignId       String
  text             String
  videoUrl         String?
  voiceUrl         String?
  status           StudentMessageStatus @default(PENDING)
  moderationReason String?
  createdAt        DateTime             @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
}

/// E17 Impact-Feed: a donor's opt-in for one feed channel. Exactly one row per
/// (userId, channel). `handle` holds the (mocked) delivery handle, e.g. a phone
/// number or Telegram chat id. IN_APP is always on and is not stored as opt-out.
model NotificationChannelPref {
  id        String      @id @default(cuid())
  userId    String
  channel   FeedChannel
  optIn     Boolean     @default(false)
  handle    String?
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  user User @relation("DonorChannelPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId])
}

/// E17 Impact-Feed: read tracking per donor + feed-item key. `feedItemKey` is
/// the stable key from `feed-builder.feedItemKey`. The unique pair makes reads
/// idempotent and feeds the update-read streak (E16 streak primitive).
model FeedRead {
  id          String   @id @default(cuid())
  userId      String
  feedItemKey String
  readAt      DateTime @default(now())

  user User @relation("DonorFeedReads", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemKey])
  @@index([userId, readAt])
}

model CorporateProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  sector      String?
  contactName String?
  logoUrl     String?
  createdAt   DateTime @default(now())

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  donations    Donation[]
  sponsorships CorporateSponsorship[]
}

model Payout {
  id          String         @id @default(cuid())
  campaignId  String         @unique
  schoolId    String
  amountCents Int
  method      DonationMethod @default(SEPA)
  reference   String
  status      PayoutStatus   @default(PENDING)
  proofNote   String?
  createdAt   DateTime       @default(now())
  sentAt      DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [schoolId], references: [id])

  // ---- E12: optional bank-feed match(es) for this payout ----
  bankTransactions BankTransaction[]
}

model CampaignUpdate {
  id         String     @id @default(cuid())
  campaignId String
  authorId   String?
  title      String
  body       String
  type       UpdateType @default(MANUAL)
  createdAt  DateTime   @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id])

  @@index([campaignId])
}

model CorporateSponsorship {
  id                 String          @id @default(cuid())
  donationId         String          @unique
  corporateProfileId String
  campaignId         String
  tier               SponsorshipTier
  fullTuition        Boolean         @default(false)
  scholarshipName    String?
  logoRecognition    Boolean         @default(false)
  recognitionKind    RecognitionKind @default(ANONYMOUS)
  impactReportOptIn  Boolean         @default(false)
  poNumber           String?
  vatId              String?
  createdAt          DateTime        @default(now())

  donation         Donation         @relation(fields: [donationId], references: [id], onDelete: Cascade)
  corporateProfile CorporateProfile @relation(fields: [corporateProfileId], references: [id], onDelete: Cascade)
  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invoice          Invoice?

  @@index([corporateProfileId])
  @@index([campaignId])
}

model Invoice {
  id            String         @id @default(cuid())
  sponsorshipId String         @unique
  invoiceNo     String         @unique
  documentType  InvoiceDocType
  netCents      Int
  vatCents      Int
  grossCents    Int
  currency      String         @default("EUR")
  vatId         String?
  poNumber      String?
  status        InvoiceStatus  @default(ISSUED)
  settledAt     DateTime?
  issuedAt      DateTime       @default(now())

  sponsorship CorporateSponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
}

/// E9 Trust-and-Safety: one moderation case per campaign (unique campaignId →
/// idempotent re-scan). The auto-flag score/level/reasons come from the pure
/// `moderation-rules.ts`; the action history lives in the reused E6 AuditLog.
model ModerationCase {
  id           String           @id @default(cuid())
  campaignId   String           @unique
  status       ModerationStatus @default(OPEN)
  riskScore    Int              @default(0)
  riskLevel    RiskLevel        @default(LOW)
  reasons      Json
  autoFlagged  Boolean          @default(false)
  decisionNote String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("ModerationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, riskScore])
}

/// E9 Trust-and-Safety: a logged fraud/risk signal for a transaction or donor.
/// Soft references (SetNull) so a deleted row never breaks the signal trail.
model FraudSignal {
  id          String    @id @default(cuid())
  kind        String
  score       Int
  riskLevel   RiskLevel @default(LOW)
  reasons     Json
  donationId  String?
  donorUserId String?
  campaignId  String?
  createdAt   DateTime  @default(now())

  donation  Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)
  donorUser User?     @relation("DonorFraud", fields: [donorUserId], references: [id], onDelete: SetNull)

  @@index([donorUserId, createdAt])
  @@index([kind, createdAt])
  @@index([campaignId])
}

/// E9 Trust-and-Safety: a dispute fed by a (mocked) Stripe chargeback webhook
/// event. Idempotent over providerEventId; never triggers a real refund.
model Chargeback {
  id              String           @id @default(cuid())
  providerEventId String           @unique
  donationId      String?
  campaignId      String?
  amountCents     Int
  currency        String           @default("EUR")
  reason          String
  status          ChargebackStatus @default(OPEN)
  evidenceNote    String?
  refundOffered   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  donation Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([campaignId])
}

/// E9 Trust-and-Safety: a community report from the campaign page. Optionally
/// anonymous (visitorId, no PII/IP); raises the moderation risk score in bulk.
model CampaignFlag {
  id             String     @id @default(cuid())
  campaignId     String
  reporterUserId String?
  visitorId      String?
  reason         FlagReason @default(OTHER)
  note           String?
  status         FlagStatus @default(OPEN)
  createdAt      DateTime   @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reporter User?    @relation("FlagReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([status])
}

/// E10 AI Coach: per-user AI token budget. A simple counter (estimated tokens),
/// NOT real billing — it just stops any one user from running unbounded
/// generations. Anchored to User; never touches the money path.
model AiTokenBudget {
  id          String   @id @default(cuid())
  userId      String   @unique
  limitTokens Int      @default(20000)
  usedTokens  Int      @default(0)
  generations Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// E10 AI Coach: a thin, optional log of a coach generation (traceability /
/// analytics). Soft reference to the user; never touches the money path.
model AiGeneration {
  id            String           @id @default(cuid())
  userId        String
  kind          AiGenerationKind
  channel       String?
  locale        String
  provider      String
  tokensCharged Int
  variantCount  Int
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// E11 KYC: the central verification case for a student or sponsor. The step
/// results (liveness/document/aml) are 1:1 children; every decision is logged to
/// the reused E6 AuditLog. riskLevel reuses the E9 RiskLevel band. Never touches
/// the money path — money still flows only to the school.
model VerificationCase {
  id                String                 @id @default(cuid())
  subjectType       VerificationSubject
  subjectUserId     String
  admissionRecordId String?
  status            VerificationCaseStatus @default(STARTED)
  reviewQueueStatus ReviewQueueStatus      @default(NOT_REQUIRED)
  riskScore         Int                    @default(0)
  riskLevel         RiskLevel              @default(LOW)
  decisionNote      String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  user            User                  @relation("VerificationSubject", fields: [subjectUserId], references: [id], onDelete: Cascade)
  reviewedBy      User?                 @relation("VerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  admissionRecord AdmissionRecord?      @relation(fields: [admissionRecordId], references: [id], onDelete: SetNull)
  liveness        LivenessResult?
  document        DocumentVerification?
  aml             AmlScreening?

  @@index([reviewQueueStatus, riskScore])
  @@index([subjectUserId])
}

/// E11 KYC: result of the liveness (video-selfie) step. Confidence and pass/fail
/// come from the pure `liveness-result.ts`; the provider only supplies the raw
/// confidence. One row per case.
model LivenessResult {
  id         String   @id @default(cuid())
  caseId     String   @unique
  provider   String
  confidence Int
  passed     Boolean
  reference  String
  createdAt  DateTime @default(now())

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

/// E11 KYC: result of the document/OCR step. The extracted fields come from the
/// (mock) OCR provider; nameMatchScore/matched come from the pure `name-match.ts`
/// against the E8 AdmissionRecord. One row per case.
model DocumentVerification {
  id                 String   @id @default(cuid())
  caseId             String   @unique
  provider           String
  extractedName      String
  extractedSchool    String?
  extractedDegree    String?
  nameMatchScore     Int
  matched            Boolean
  registrarConfirmed Boolean  @default(false)
  reference          String
  createdAt          DateTime @default(now())

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

/// E11 KYC: result of the AML screening step for a sponsor above threshold. The
/// decision comes from the pure `aml-decision.ts`; the sanctioned-country check
/// reuses the static E9 list. One row per case.
model AmlScreening {
  id          String      @id @default(cuid())
  caseId      String      @unique
  provider    String
  amountCents Int
  country     String
  decision    AmlDecision
  reasons     Json
  reference   String
  createdAt   DateTime    @default(now())

  case VerificationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

/// E12 — Append-only transaction ledger (a reusable money primitive E14/CSRD will
/// build on). Every donation/payout/disbursement writes exactly one IMMUTABLE row:
/// there is no `updatedAt`, no soft-delete, and the LedgerService exposes only
/// append() + read() — no update/delete (Constitution IV). Each entry is chained to
/// its predecessor via a SHA-256 hash (prevHash → entryHash) so the chain is
/// tamper-evident. Money always flows to the school.
model LedgerEntry {
  id          String          @id @default(cuid())
  sequence    Int
  entryType   LedgerEntryType
  amountCents Int
  currency    String          @default("EUR")
  schoolId    String
  actorUserId String?
  reason      String
  refType     String?
  refId       String?
  prevHash    String          @default("")
  entryHash   String
  createdAt   DateTime        @default(now())

  school School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  actor  User?   @relation("LedgerActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  // ---- E14: additive ESG tag (read-only ref; the entry itself is never mutated) ----
  esgTag EsgTag?

  @@unique([schoolId, sequence])
  @@index([schoolId, createdAt])
  @@index([entryType])
}

/// E12 — A transaction reported by the bank-feed provider (mock by default; Plaid
/// behind the swappable `BankFeedProvider` seam). Idempotent via (provider,
/// externalId). Matched against system Payouts by the pure reconciliation cores.
model BankTransaction {
  id              String   @id @default(cuid())
  provider        String
  externalId      String
  schoolId        String
  amountCents     Int
  currency        String   @default("EUR")
  reference       String?
  postedAt        DateTime
  matchedPayoutId String?
  raw             Json?
  createdAt       DateTime @default(now())

  school        School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  matchedPayout Payout? @relation(fields: [matchedPayoutId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([schoolId, postedAt])
}

/// E12 — A persisted reconciliation run per school (history/audit). The detail rows
/// are computed at request time by the pure cores; only the summary counters are
/// stored here.
model Reconciliation {
  id               String   @id @default(cuid())
  schoolId         String
  matchedCount     Int      @default(0)
  pendingCount     Int      @default(0)
  unmatchedCount   Int      @default(0)
  discrepancyCount Int      @default(0)
  bankTxCount      Int      @default(0)
  runAt            DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, runAt])
}

/// E13 — A known employer matching program (à la Double the Donation). Static-ish:
/// seeded into the DB and held in-memory by the MockEmployerMatchProvider for tests.
/// `matchRatio` is ×100 (100 = 1:1, 200 = 2:1). The annual cap is per donor per year.
model EmployerMatchProgram {
  id               String                   @id @default(cuid())
  domain           String                   @unique
  employerName     String
  matchRatio       Int
  annualCapCents   Int
  minDonationCents Int                      @default(0)
  integrationLevel EmployerIntegrationLevel @default(PORTAL)
  applyUrlTemplate String?
  active           Boolean                  @default(true)
  createdAt        DateTime                 @default(now())

  claims MatchClaim[]
}

/// E13 — A donor's claim of an employer match against a triggering donation.
/// Idempotent per `donationId`. A CLAIMED claim has already committed its match
/// funds as a normal CORPORATE Donation (`matchDonationId`) to the same campaign —
/// money still flows only to the school, never to the student.
model MatchClaim {
  id              String           @id @default(cuid())
  donationId      String           @unique
  matchDonationId String?          @unique
  programId       String
  donorUserId     String?
  campaignId      String
  employerName    String
  matchCents      Int
  status          MatchClaimStatus @default(CLAIMED)
  applyUrl        String?
  pdfRef          String?
  year            Int
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  program       EmployerMatchProgram @relation(fields: [programId], references: [id])
  donor         User?                @relation("DonorMatchClaims", fields: [donorUserId], references: [id], onDelete: SetNull)
  campaign      Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donation      Donation             @relation("TriggeringDonation", fields: [donationId], references: [id], onDelete: Cascade)
  matchDonation Donation?            @relation("MatchDonation", fields: [matchDonationId], references: [id], onDelete: SetNull)

  @@index([donorUserId, createdAt])
  @@index([campaignId])
  @@index([status])
}

/// E14 ESG/CSRD — An additive compliance tag on an immutable ledger entry. Unique
/// per ledgerEntryId (re-tag replaces). The referenced LedgerEntry is NEVER mutated,
/// so the append-only hash chain stays verifiable (relations are not hashed).
model EsgTag {
  id             String      @id @default(cuid())
  ledgerEntryId  String      @unique
  category       EsgCategory
  note           String?
  taggedByUserId String?
  createdAt      DateTime    @default(now())

  ledgerEntry LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  taggedBy    User?       @relation("EsgTagTagger", fields: [taggedByUserId], references: [id], onDelete: SetNull)

  @@index([category])
}

/// E14 ESG/CSRD — A persisted snapshot of a generated report (standard + period +
/// mapped metrics/annotations). `metricsJson` is an illustrative mapping snapshot,
/// not a certified disclosure schema.
model EsgReport {
  id              String         @id @default(cuid())
  standard        ReportStandard
  periodStart     DateTime
  periodEnd       DateTime
  metricsJson     Json
  createdByUserId String?
  createdAt       DateTime       @default(now())

  createdBy User? @relation("EsgReportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([standard, createdAt])
}

/// E14 ESG/CSRD — A time-limited, read-only auditor access grant. Only the SHA-256
/// hash of the token is stored (E8 one-time-token pattern); the raw token is shown
/// once. A grant is valid while `revokedAt == null && expiresAt > now`.
model AuditorAccessGrant {
  id              String    @id @default(cuid())
  label           String
  tokenHash       String    @unique
  scope           String?
  expiresAt       DateTime
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())

  createdBy User? @relation("AuditorGrantCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([expiresAt])
}

/// E15 referral engine — a donor's own referral link. The link is the donor's own
/// shareable asset (not an authorization token), so a displayable `code` is stored
/// alongside the `codeHash` used for timing-safe lookup when attributing a donation.
/// Exactly one per donor.
model ReferralLink {
  id               String   @id @default(cuid())
  donorUserId      String   @unique
  code             String   @unique
  codeHash         String   @unique
  optInLeaderboard Boolean  @default(false)
  createdAt        DateTime @default(now())

  donorUser    User                  @relation("DonorReferralLink", fields: [donorUserId], references: [id], onDelete: Cascade)
  attributions ReferralAttribution[]
}

/// E15 referral engine — an advocate a student invited to promote their campaign.
/// Strictly hash-only (the raw share link is shown once at creation, E8 pattern).
/// Up to 15 ACTIVE invites per campaign (enforced in the service).
model AdvocateInvite {
  id         String               @id @default(cuid())
  campaignId String
  name       String
  email      String?
  codeHash   String               @unique
  status     AdvocateInviteStatus @default(ACTIVE)
  createdAt  DateTime             @default(now())

  campaign     Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attributions ReferralAttribution[]

  @@index([campaignId])
}

/// E15 referral engine — links a code (referral OR advocate) to exactly one donation.
/// `donationId @unique` is the dedupe guarantee: a donation counts at most once.
/// Money-free: carries no amount and no recipient — attribution never touches the
/// money path, funds still flow to the school.
model ReferralAttribution {
  id               String       @id @default(cuid())
  kind             ReferralKind
  referralLinkId   String?
  advocateInviteId String?
  donationId       String       @unique
  convertedAt      DateTime     @default(now())

  referralLink   ReferralLink?   @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
  advocateInvite AdvocateInvite? @relation(fields: [advocateInviteId], references: [id], onDelete: Cascade)
  donation       Donation        @relation("DonationReferral", fields: [donationId], references: [id], onDelete: Cascade)

  @@index([referralLinkId])
  @@index([advocateInviteId])
}

// ============================================================================
// E18 Groups-Engine — one engine, two modes (COHORT | GIVING_CIRCLE).
// Student cohorts and donor giving-circles share the SAME group / membership /
// leaderboard / shared-goal / invite / voting / chat / analytics infrastructure;
// only `Group.mode` discriminates the surface. Money-free: groups are a social /
// coordination layer. `GroupContribution` mirrors an existing donation for the
// leaderboard/analytics; the cohort match runs through the EXISTING E5 corporate
// flow. E18 never writes to a Donation/Payout — funds still flow to the school.
// Progress / stretch-unlock / leaderboard / analytics are derived on read (no DB
// model), reusing the E16 gamification primitives.
// ============================================================================

/// E18 — a group (cohort team or giving circle). `sharedGoalCents` is the TARGET
/// (input); progress is derived on read. `stretchThresholdPct` drives the
/// recognition-only stretch unlock (default 80). Money-free.
model Group {
  id                  String          @id @default(cuid())
  mode                GroupMode
  visibility          GroupVisibility @default(PRIVATE)
  name                String
  description         String?
  logoUrl             String?
  sharedGoalCents     Int             @default(0)
  stretchThresholdPct Int             @default(80)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  members       GroupMember[]
  invites       GroupInvite[]
  campaigns     GroupCampaign[]
  contributions GroupContribution[]
  votes         GroupVote[]
  messages      GroupMessage[]

  @@index([mode, visibility])
}

/// E18 — membership + per-group role. Exactly one row per (group, user).
model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(CONTRIBUTOR)
  joinedAt DateTime  @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
}

/// E18 — an invite, hash-only (E15/E8 one-time-token pattern). The raw token is
/// only ever in the invite link/QR; only its `codeHash` is persisted. `role` is
/// the role the joiner receives.
model GroupInvite {
  id        String            @id @default(cuid())
  groupId   String
  codeHash  String            @unique
  role      GroupRole         @default(CONTRIBUTOR)
  status    GroupInviteStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime          @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, status])
}

/// E18 — a cohort sub-campaign link: an existing Campaign rolled into the team
/// goal. Exactly one row per (group, campaign).
model GroupCampaign {
  id            String   @id @default(cuid())
  groupId       String
  campaignId    String
  addedByUserId String
  createdAt     DateTime @default(now())

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  campaign Campaign @relation("GroupCampaigns", fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([groupId, campaignId])
  @@index([groupId])
}

/// E18 — a giving-circle contribution: a MONEY-FREE mirror of an existing donation
/// for the leaderboard/analytics. `valueCents` projects the already-recorded gift.
/// No new money path; exactly one row per (group, donation).
model GroupContribution {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  donationId String   @unique
  valueCents Int
  createdAt  DateTime @default(now())

  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation("GroupContributions", fields: [userId], references: [id], onDelete: Cascade)
  donation Donation @relation("GroupContributionDonation", fields: [donationId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

/// E18 — a group vote: which campaign the group supports next.
model GroupVote {
  id        String          @id @default(cuid())
  groupId   String
  question  String
  status    GroupVoteStatus @default(OPEN)
  createdAt DateTime        @default(now())

  group   Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  options GroupVoteOption[]
  ballots GroupVoteBallot[]

  @@index([groupId, status])
}

/// E18 — a vote option (one campaign).
model GroupVoteOption {
  id         String @id @default(cuid())
  voteId     String
  campaignId String
  label      String

  vote     GroupVote         @relation(fields: [voteId], references: [id], onDelete: Cascade)
  campaign Campaign          @relation("GroupVoteCampaign", fields: [campaignId], references: [id], onDelete: Cascade)
  ballots  GroupVoteBallot[]

  @@index([voteId])
}

/// E18 — a ballot. Exactly one per (vote, user): a member votes once.
model GroupVoteBallot {
  id       String   @id @default(cuid())
  voteId   String
  optionId String
  userId   String
  castAt   DateTime @default(now())

  vote   GroupVote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  option GroupVoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User            @relation("GroupBallots", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([voteId, userId])
  @@index([optionId])
}

/// E18 — a moderated group chat message (E9 keyword/slur filter). Only APPROVED
/// messages are shown in the chat history; REJECTED rows keep the reason.
model GroupMessage {
  id               String             @id @default(cuid())
  groupId          String
  userId           String
  text             String
  status           GroupMessageStatus @default(APPROVED)
  moderationReason String?
  createdAt        DateTime           @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation("GroupMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, status])
}
