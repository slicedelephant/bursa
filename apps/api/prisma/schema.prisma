// Bursa — Funding Platform. Schema derived from specs/001-bursa-funding-platform/data-model.md.
// Money is stored as integer cents (EUR). IDs are cuid().

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  DONOR
  SPONSOR
  ADMIN
  SCHOOL_ADMIN
}

/// Self-serve onboarding state machine for a partner school (E8). The transitions
/// are owned by the pure `onboarding-status.ts` util; a school can only approve
/// campaigns and receive payouts once it reaches ACTIVE.
enum SchoolOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  ACTIVE
}

enum CampaignStatus {
  DRAFT
  PENDING_VERIFICATION
  LIVE
  FUNDED
  DISBURSED
  CLOSED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DonationMethod {
  CARD
  SEPA
}

enum DonationType {
  PRIVATE
  CORPORATE
}

enum DonationStatus {
  PENDING
  PLEDGED
  CAPTURED
  SUCCEEDED
  FAILED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  SENT
  CONFIRMED
}

enum UpdateType {
  MANUAL
  SYSTEM
}

enum TributeType {
  HONOR
  MEMORY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum NotificationType {
  THANK_YOU
  MILESTONE
  IMPACT_UPDATE
  GOAL_REACHED
  RECURRING_CHARGE
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum SponsorshipTier {
  SEMESTER
  YEAR
  FULL
  CUSTOM
}

enum RecognitionKind {
  ANONYMOUS
  LOGO
  NAMED
}

enum InvoiceDocType {
  DONATION
  SPONSORING
}

enum InvoiceStatus {
  ISSUED
  PENDING
  PAID
}

/// E9 Trust-and-Safety: lifecycle of a campaign moderation case. Transitions are
/// owned by the pure `moderation-rules.ts` (`decideModeration`); REJECT freezes
/// the campaign.
enum ModerationStatus {
  OPEN
  APPROVED
  REJECTED
  ESCALATED
}

/// E9 Trust-and-Safety: derived risk band for a numeric score (fraud-score.ts /
/// donor-risk.ts). Drives queue sorting and heat-map colouring.
enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// E9 Trust-and-Safety: dispute lifecycle. Transitions in `chargeback-rules.ts`.
enum ChargebackStatus {
  OPEN
  EVIDENCE_SUBMITTED
  REFUND_OFFERED
  WON
  LOST
}

/// E9 Trust-and-Safety: reason a community member reports a campaign.
enum FlagReason {
  SCAM
  DUPLICATE
  INAPPROPRIATE
  MISLEADING
  OTHER
}

/// E9 Trust-and-Safety: lifecycle of a community flag.
enum FlagStatus {
  OPEN
  REVIEWED
  DISMISSED
}

/// E10 AI Coach: which kind of text a coach generation produced.
enum AiGenerationKind {
  TITLE
  STORY
  SHARE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(DONOR)
  displayName  String
  anonymizedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  studentProfile     StudentProfile?
  corporateProfile   CorporateProfile?
  donations          Donation[]              @relation("DonorDonations")
  updates            CampaignUpdate[]
  verifications      AdmissionVerification[] @relation("VerifiedBy")
  recurringPledges   RecurringPledge[]       @relation("DonorRecurring")
  subscriptions      UpdateSubscription[]    @relation("DonorSubscriptions")
  notifications      Notification[]
  auditLogs          AuditLog[]              @relation("AuditActor")
  schoolAdmin        SchoolAdmin?
  reviewedAdmissions AdmissionRecord[]       @relation("AdmissionReviewer")

  // ---- E9: trust & safety (donor account freeze + risk score) ----
  frozen       Boolean   @default(false)
  frozenAt     DateTime?
  freezeReason String?
  riskScore    Int       @default(0)
  riskLevel    RiskLevel @default(LOW)

  fraudSignals      FraudSignal[]    @relation("DonorFraud")
  moderationReviews ModerationCase[] @relation("ModerationReviewer")
  campaignFlags     CampaignFlag[]   @relation("FlagReporter")

  // ---- E10: AI fundraising coach (per-user token budget + generation log) ----
  aiTokenBudget AiTokenBudget?
  aiGenerations AiGeneration[]
}

/// Append-only access/security audit trail. Metadata is PII-redacted before
/// it is persisted (see SecurityModule's AuditService).
model AuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String?
  targetType  String?
  targetId    String?
  ip          String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([actorUserId])
}

/// Privacy-aware product/funnel analytics (E7). visitorId is an anonymous,
/// client-generated id (never IP, no PII). metadata is PII-redacted before it is
/// persisted (see ObservabilityModule/AnalyticsService). Soft references only
/// (no FK constraints) so analytics never blocks a business operation.
model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String
  visitorId  String?
  sessionId  String?
  userId     String?
  campaignId String?
  path       String?
  step       String?
  requestId  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([campaignId])
}

model School {
  id               String   @id @default(cuid())
  name             String
  country          String
  city             String?
  website          String?
  logoUrl          String?
  /// URL-safe handle for the branded school-admin portal (E8). Optional/unique.
  slug             String?  @unique
  payoutVerified   Boolean  @default(false)
  payoutAccountRef String?
  createdAt        DateTime @default(now())

  // ---- E8: self-serve onboarding + payout data ----
  onboardingStatus    SchoolOnboardingStatus @default(NOT_STARTED)
  bankAccountName     String?
  iban                String?
  bic                 String?
  taxId               String?
  contactName         String?
  contactEmail        String?
  /// Mock e-signature audit fields (no real DocuSign call — see EsignatureProvider).
  agreementSignedAt   DateTime?
  agreementSignerName String?
  agreementRef        String?

  campaigns        Campaign[]
  payouts          Payout[]
  admins           SchoolAdmin[]
  admissionRecords AdmissionRecord[]
  onboardingTokens SchoolOnboardingToken[]
  webhookEvents    SchoolWebhookEvent[]
}

/// Binds a User (role SCHOOL_ADMIN) to exactly one School (E8). One user admins
/// one school in the prototype; a school may have several admins.
model SchoolAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  schoolId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// A row from an imported admission list (E8). A VERIFIED admission is the
/// trust anchor that lets a matching student campaign go live (Constitution II).
model AdmissionRecord {
  id           String             @id @default(cuid())
  schoolId     String
  studentEmail String
  studentName  String
  programName  String
  admissionRef String
  status       VerificationStatus @default(PENDING)
  note         String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("AdmissionReviewer", fields: [reviewedById], references: [id])

  @@unique([schoolId, admissionRef])
  @@index([schoolId, status])
}

/// Single-use, hashed onboarding link token for the hosted registration flow
/// (E8, à la Stripe Connect). Only the SHA-256 hash is stored, never the raw token.
model SchoolOnboardingToken {
  id        String    @id @default(cuid())
  schoolId  String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// Logged outbound school webhook event (E8). The prototype emitter only persists
/// + structured-logs the event; real HTTP delivery/retries are out of scope.
model SchoolWebhookEvent {
  id        String   @id @default(cuid())
  schoolId  String
  type      String
  status    String   @default("LOGGED")
  payload   Json
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, createdAt])
}

model StudentProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  country        String
  photoUrl       String?
  story          String
  recommendation String?
  createdAt      DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?
}

model Campaign {
  id               String         @id @default(cuid())
  studentProfileId String         @unique
  schoolId         String
  programName      String
  title            String
  story            String
  storyBackground  String?
  storyChallenge   String?
  storyVision      String?
  videoUrl         String?
  goalCents        Int
  currency         String         @default("EUR")
  raisedCents      Int            @default(0)
  tipsCents        Int            @default(0)
  status           CampaignStatus @default(DRAFT)
  deadline         DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // ---- E9: trust & safety (freeze flags; never touches the money path) ----
  frozen       Boolean   @default(false)
  frozenAt     DateTime?
  freezeReason String?

  studentProfile   StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  school           School                 @relation(fields: [schoolId], references: [id])
  verification     AdmissionVerification?
  donations        Donation[]
  updates          CampaignUpdate[]
  payout           Payout?
  recurringPledges RecurringPledge[]
  subscriptions    UpdateSubscription[]
  notifications    Notification[]
  sponsorships     CorporateSponsorship[]
  moderationCase   ModerationCase?
  flags            CampaignFlag[]
  chargebacks      Chargeback[]

  @@index([status])
  @@index([schoolId])
}

model AdmissionVerification {
  id           String             @id @default(cuid())
  campaignId   String             @unique
  status       VerificationStatus @default(PENDING)
  admissionRef String?
  note         String?
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime           @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  verifiedBy User?    @relation("VerifiedBy", fields: [verifiedById], references: [id])
}

model Donation {
  id                 String         @id @default(cuid())
  campaignId         String
  donorUserId        String?
  corporateProfileId String?
  amountCents        Int
  tipCents           Int            @default(0)
  currency           String         @default("EUR")
  method             DonationMethod
  type               DonationType
  status             DonationStatus @default(PENDING)
  providerRef        String?
  pledgeRef          String?
  capturedAt         DateTime?
  message            String?
  anonymous          Boolean        @default(false)
  donorName          String?
  /// Optional self-declared donor country, used only for the school dashboard's
  /// donor-geography breakdown (E8). Never required, never PII-linked.
  donorCountry       String?
  recurringPledgeId  String?
  tributeType        TributeType?
  tributeName        String?
  createdAt          DateTime       @default(now())

  campaign         Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donorUser        User?                 @relation("DonorDonations", fields: [donorUserId], references: [id])
  corporateProfile CorporateProfile?     @relation(fields: [corporateProfileId], references: [id])
  recurringPledge  RecurringPledge?      @relation(fields: [recurringPledgeId], references: [id])
  sponsorship      CorporateSponsorship?
  fraudSignals     FraudSignal[]
  chargebacks      Chargeback[]

  @@index([campaignId])
  @@index([donorUserId])
  @@index([recurringPledgeId])
}

model RecurringPledge {
  id                String          @id @default(cuid())
  donorUserId       String
  campaignId        String
  amountCents       Int
  currency          String          @default("EUR")
  status            RecurringStatus @default(ACTIVE)
  chargesCount      Int             @default(0)
  totalChargedCents Int             @default(0)
  nextRunAt         DateTime
  lastChargedAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  donorUser User       @relation("DonorRecurring", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donations Donation[]

  @@index([donorUserId])
  @@index([campaignId])
  @@index([status, nextRunAt])
}

model UpdateSubscription {
  id          String   @id @default(cuid())
  donorUserId String
  campaignId  String
  createdAt   DateTime @default(now())

  donorUser User     @relation("DonorSubscriptions", fields: [donorUserId], references: [id], onDelete: Cascade)
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([donorUserId, campaignId])
  @@index([campaignId])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  type        NotificationType
  channel     NotificationChannel @default(IN_APP)
  title       String
  body        String
  campaignId  String?
  emailLogged Boolean             @default(false)
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model CorporateProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  companyName String
  sector      String?
  contactName String?
  logoUrl     String?
  createdAt   DateTime @default(now())

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  donations    Donation[]
  sponsorships CorporateSponsorship[]
}

model Payout {
  id          String         @id @default(cuid())
  campaignId  String         @unique
  schoolId    String
  amountCents Int
  method      DonationMethod @default(SEPA)
  reference   String
  status      PayoutStatus   @default(PENDING)
  proofNote   String?
  createdAt   DateTime       @default(now())
  sentAt      DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [schoolId], references: [id])
}

model CampaignUpdate {
  id         String     @id @default(cuid())
  campaignId String
  authorId   String?
  title      String
  body       String
  type       UpdateType @default(MANUAL)
  createdAt  DateTime   @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id])

  @@index([campaignId])
}

model CorporateSponsorship {
  id                 String          @id @default(cuid())
  donationId         String          @unique
  corporateProfileId String
  campaignId         String
  tier               SponsorshipTier
  fullTuition        Boolean         @default(false)
  scholarshipName    String?
  logoRecognition    Boolean         @default(false)
  recognitionKind    RecognitionKind @default(ANONYMOUS)
  impactReportOptIn  Boolean         @default(false)
  poNumber           String?
  vatId              String?
  createdAt          DateTime        @default(now())

  donation         Donation         @relation(fields: [donationId], references: [id], onDelete: Cascade)
  corporateProfile CorporateProfile @relation(fields: [corporateProfileId], references: [id], onDelete: Cascade)
  campaign         Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  invoice          Invoice?

  @@index([corporateProfileId])
  @@index([campaignId])
}

model Invoice {
  id            String         @id @default(cuid())
  sponsorshipId String         @unique
  invoiceNo     String         @unique
  documentType  InvoiceDocType
  netCents      Int
  vatCents      Int
  grossCents    Int
  currency      String         @default("EUR")
  vatId         String?
  poNumber      String?
  status        InvoiceStatus  @default(ISSUED)
  settledAt     DateTime?
  issuedAt      DateTime       @default(now())

  sponsorship CorporateSponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
}

/// E9 Trust-and-Safety: one moderation case per campaign (unique campaignId →
/// idempotent re-scan). The auto-flag score/level/reasons come from the pure
/// `moderation-rules.ts`; the action history lives in the reused E6 AuditLog.
model ModerationCase {
  id           String           @id @default(cuid())
  campaignId   String           @unique
  status       ModerationStatus @default(OPEN)
  riskScore    Int              @default(0)
  riskLevel    RiskLevel        @default(LOW)
  reasons      Json
  autoFlagged  Boolean          @default(false)
  decisionNote String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("ModerationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, riskScore])
}

/// E9 Trust-and-Safety: a logged fraud/risk signal for a transaction or donor.
/// Soft references (SetNull) so a deleted row never breaks the signal trail.
model FraudSignal {
  id          String    @id @default(cuid())
  kind        String
  score       Int
  riskLevel   RiskLevel @default(LOW)
  reasons     Json
  donationId  String?
  donorUserId String?
  campaignId  String?
  createdAt   DateTime  @default(now())

  donation  Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)
  donorUser User?     @relation("DonorFraud", fields: [donorUserId], references: [id], onDelete: SetNull)

  @@index([donorUserId, createdAt])
  @@index([kind, createdAt])
  @@index([campaignId])
}

/// E9 Trust-and-Safety: a dispute fed by a (mocked) Stripe chargeback webhook
/// event. Idempotent over providerEventId; never triggers a real refund.
model Chargeback {
  id              String           @id @default(cuid())
  providerEventId String           @unique
  donationId      String?
  campaignId      String?
  amountCents     Int
  currency        String           @default("EUR")
  reason          String
  status          ChargebackStatus @default(OPEN)
  evidenceNote    String?
  refundOffered   Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  donation Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([campaignId])
}

/// E9 Trust-and-Safety: a community report from the campaign page. Optionally
/// anonymous (visitorId, no PII/IP); raises the moderation risk score in bulk.
model CampaignFlag {
  id             String     @id @default(cuid())
  campaignId     String
  reporterUserId String?
  visitorId      String?
  reason         FlagReason @default(OTHER)
  note           String?
  status         FlagStatus @default(OPEN)
  createdAt      DateTime   @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reporter User?    @relation("FlagReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([status])
}

/// E10 AI Coach: per-user AI token budget. A simple counter (estimated tokens),
/// NOT real billing — it just stops any one user from running unbounded
/// generations. Anchored to User; never touches the money path.
model AiTokenBudget {
  id          String   @id @default(cuid())
  userId      String   @unique
  limitTokens Int      @default(20000)
  usedTokens  Int      @default(0)
  generations Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// E10 AI Coach: a thin, optional log of a coach generation (traceability /
/// analytics). Soft reference to the user; never touches the money path.
model AiGeneration {
  id            String           @id @default(cuid())
  userId        String
  kind          AiGenerationKind
  channel       String?
  locale        String
  provider      String
  tokensCharged Int
  variantCount  Int
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
