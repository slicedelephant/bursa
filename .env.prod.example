# Production deploy — copy to `.env` next to docker-compose.prod.yml on the VPS.
# Used by docker-compose.prod.yml only (Traefik itself is already configured on the host).

# Public hostname → https://${SUBDOMAIN}.${DOMAIN_NAME}
DOMAIN_NAME=slicedelephant.de
SUBDOMAIN=bursa

# Database (internal to the compose stack)
POSTGRES_USER=bursa
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=bursa

# JWT signing — use a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-secret

# Seed the synthetic demo data when the API container starts.
# true  → resets to the clean 11-campaign demo on every (re)start (good for a public demo)
# false → data persists across restarts (seed once manually instead)
SEED_ON_START=true
