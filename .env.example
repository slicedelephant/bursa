# Copy to apps/api/.env for the backend. Local-only values shown.

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://fundingapp:fundingapp@localhost:5433/fundingapp?schema=public"

# JWT signing secret for the prototype (change for any real deployment)
JWT_SECRET="dev-only-change-me"
JWT_EXPIRES_IN="7d"

# API
PORT=3000
CORS_ORIGIN="http://localhost:4200"

# Payment provider selection (All-or-Nothing engine).
#   "mock"   — default, deterministic, runs without any keys.
#   "stripe" — real stripe-node SDK; used ONLY when STRIPE_SECRET_KEY is also set
#              (and `npm --prefix apps/api i stripe` is installed). Otherwise the
#              factory transparently falls back to "mock".
PAYMENT_PROVIDER="mock"
# STRIPE_SECRET_KEY="sk_test_..."

# Security hardening (E6).
# Webhook signature secret — REQUIRED in production when PAYMENT_PROVIDER=stripe.
# Used to verify the HMAC signature on POST /api/payments/webhook.
# STRIPE_WEBHOOK_SECRET="whsec_..."
#
# Optional admin MFA step-up: when set, sensitive admin actions (campaign verify)
# require a valid TOTP in the `x-mfa-token` header. Leave unset in dev (no-op).
# ADMIN_TOTP_SECRET=""
#
# NOTE: in production (NODE_ENV=production) the API refuses to boot if JWT_SECRET
# is a known default or shorter than 32 chars, or if stripe secrets are missing
# while PAYMENT_PROVIDER=stripe (see apps/api/src/security/env-validation.ts).

# Only needed to (re)generate synthetic profile images at seed time.
# The seed script also falls back to reading OPENAI_KEY from 06_IT/.env if unset here.
# OPENAI_KEY="sk-..."
